# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/eduprime_db?schema=public"

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change_this_to_a_very_long_random_string_in_production"
JWT_EXPIRES_IN="7d"

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003"

# ─── SULEKHA API ─────────────────────────────────────────────────────────────
SULEKHA_API_KEY=""
SULEKHA_API_URL="https://api.sulekha.com"

# ─── EMAIL (Nodemailer) ───────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="EduPrime <no-reply@eduprime.in>"

# ─── FILE UPLOAD ─────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10

# ─── FRONTEND URLs ───────────────────────────────────────────────────────────
STUDENT_URL="https://student.eduprime.in"
SALES_URL="https://sales.eduprime.in"
ADMIN_URL="https://admin.eduprime.in"
EXPENSES_URL="https://expenses.eduprime.in"

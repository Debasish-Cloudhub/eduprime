# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=eduprime
POSTGRES_PASSWORD=eduprime_strong_password_change_me
POSTGRES_DB=eduprime_db

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://student.eduprime.in,https://sales.eduprime.in,https://admin.eduprime.in,https://expenses.eduprime.in

# ─── Frontend API URL (used by Next.js build) ────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.eduprime.in/api/v1

# ─── Sulekha ──────────────────────────────────────────────────────────────────
SULEKHA_API_KEY=
SULEKHA_API_URL=https://api.sulekha.com

# ─── SMTP (for SLA breach emails) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
